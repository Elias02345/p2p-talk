# ---------------------------------------------------------------------------
# p2p-talk signaling server — environment configuration
# Copy to .env on first run (install.sh does this and generates the secrets).
# Never commit a real .env. Never ship default secrets.
# ---------------------------------------------------------------------------

# --- Server ---
PORT=3000
NODE_ENV=production
# Host interface the signaling port is published on. 0.0.0.0 = reachable by a
# separate CloudGate VM at <server-ip>:PORT. Use 127.0.0.1 if a local proxy fronts it.
SIGNALING_BIND=0.0.0.0
# Public host clients connect to (used to build TURN URLs). e.g. p2p-talk.elias02345.de
PUBLIC_HOST=
# Tighten to your app's origin if browser clients are used; mobile apps ignore CORS.
CORS_ORIGIN=*

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20

# --- WebSocket ---
WS_HEARTBEAT_INTERVAL=30000

# --- Database (SACRED PATH — never touched by the updater) ---
# In production (Docker) this points at the mounted volume: /app/data/p2ptalk.db
DB_PATH=./p2ptalk.db

# --- Auto-update (headless) ---
# Branch the auto-updater tracks. 'main' = stable. 'dev' = pre-release.
UPDATE_BRANCH=main

# --- Auth (REQUIRED — generated on first install, never use a default) ---
# openssl rand -base64 48
JWT_SECRET=
JWT_TTL_SECONDS=86400
CHALLENGE_TTL_MS=120000

# --- Relay (TURN) provider ---
# How the relay fallback is provided:
#   coturn     self-hosted coturn (needs a publicly reachable TURN port)
#   cloudflare Cloudflare managed TURN — WORKS BEHIND cgNAT, NO public IP (recommended here)
#   static     any hosted TURN via fixed URLs + credentials
#   none       STUN only (direct P2P works in most networks; no relay)
TURN_MODE=coturn

# -- coturn mode --
# Shared secret between this server and coturn (use-auth-secret). Generated on install.
TURN_SHARED_SECRET=
# Host clients reach coturn on. Defaults to PUBLIC_HOST if empty.
TURN_HOST=
TURN_PORT=3478
TURN_TLS_PORT=5349
TURN_REALM=p2p-talk
TURN_TTL=3600
# cgNAT / CloudGate tunnel -> "tls-first" (TURN over TLS/TCP). Public IP -> "udp-first".
TURN_TRANSPORT=tls-first

# -- cloudflare mode (cgNAT-friendly, no public IP) --
# Create a TURN key at dash.cloudflare.com -> Realtime -> TURN; keep these server-side.
CF_TURN_KEY_ID=
CF_TURN_API_TOKEN=

# -- static mode (any hosted TURN) --
TURN_URLS=
TURN_USERNAME=
TURN_CREDENTIAL=

# --- Cloudflare Tunnel (optional bundled cloudflared) ---
# If set, the stack runs a cloudflared container (compose profile "tunnel").
# Leave empty if CloudGate / an external cloudflared already manages the tunnel.
# Map your hostname to http://localhost:${PORT} in the Cloudflare dashboard / CloudGate.
TUNNEL_TOKEN=
