# ---------------------------------------------------------------------------
# p2p-talk signaling server — environment configuration
# Copy to .env on first run (install.sh does this and generates the secrets).
# Never commit a real .env. Never ship default secrets.
# ---------------------------------------------------------------------------

# --- Server ---
PORT=3000
NODE_ENV=production
# Public host clients connect to (used to build TURN URLs). e.g. p2p-talk.elias02345.de
PUBLIC_HOST=
# Tighten to your app's origin if browser clients are used; mobile apps ignore CORS.
CORS_ORIGIN=*

# --- Rate limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20

# --- WebSocket ---
WS_HEARTBEAT_INTERVAL=30000

# --- Database (SACRED PATH — never touched by the updater) ---
# In production (Docker) this points at the mounted volume: /app/data/p2ptalk.db
DB_PATH=./p2ptalk.db

# --- Auto-update (headless) ---
# Branch the auto-updater tracks. 'main' = stable. 'dev' = pre-release.
UPDATE_BRANCH=main

# --- Auth (REQUIRED — generated on first install, never use a default) ---
# openssl rand -base64 48
JWT_SECRET=
JWT_TTL_SECONDS=86400
CHALLENGE_TTL_MS=120000

# --- TURN / coturn (relay fallback) ---
# Shared secret between this server and coturn (use-auth-secret). Generated on install.
# openssl rand -base64 48
TURN_SHARED_SECRET=
# Host clients reach coturn on. Defaults to PUBLIC_HOST if empty.
TURN_HOST=
TURN_PORT=3478
TURN_TLS_PORT=5349
TURN_REALM=p2p-talk
TURN_TTL=3600
# cgNAT / CloudGate tunnel -> "tls-first" (TURN over TLS/TCP). Public IP -> "udp-first".
TURN_TRANSPORT=tls-first
